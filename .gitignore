# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!example.tfvars
.terraform.lock.hcl.bak
crash.log

# Helm
# Ignore dependency downloads (helm dependency update output) but not authored charts
**/charts/
!helm/charts/
**/Chart.lock

# Kubernetes
kubeconfig
*-kubeconfig
*.kubeconfig

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Logs
*.log
logs/

# Secrets — should NEVER be committed
.env
.env.*
!.env.example
secrets/
*-secret.yaml
*-secrets.yaml
# Helm templates that contain "secret" in the name are NOT real secrets — allow them
!helm/**/templates/**/*-secret.yaml
!helm/**/templates/**/*-secrets.yaml

# Build artifacts
dist/
build/
node_modules/

# Tooling local state (never commit)
.claude/
.playwright-mcp/
ruvector.db
graphify-out/
